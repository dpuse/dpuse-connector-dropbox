    "type": "module",
    "sideEffects": false,
    "homepage": "https://www.dpuse.app",
    "bugs": {
        "url": "https://github.com/dpuse/dpuse-connector-dropbox/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/dpuse/dpuse-connector-dropbox.git"
    },
    "module": "./dist/dpuse-connector-dropbox.es.js",
    "types": "./dist/types/src/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/dpuse-connector-dropbox.es.js",
            "types": "./dist/types/src/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22",
        "npm": ">=11"
    },
    "prettier": "@dpuse/dpuse-development/prettierrc",
    "allowScripts": {
        "esbuild@0.28.1": true,
        "fsevents@2.3.3": true,
        "sharp@0.34.5": true,
        "unrs-resolver@1.11.1": true,
        "workerd@1.20260625.1": true
    },
    "scripts": {
        "audit": "node -e \"import('@dpuse/dpuse-development').then(m => m.auditDependencies())\"",
        "build": "node -e \"import('@dpuse/dpuse-development').then(m => m.buildProject())\" && node -e \"import('@dpuse/dpuse-development').then(m => m.documentBundleSizes())\"",
        "check": "node -e \"import('@dpuse/dpuse-development').then(m => m.checkDependencies())\"",
        "document": "node -e \"import('@dpuse/dpuse-development').then(m => m.documentDependencies(['MIT']))\"",
        "format": "node -e \"import('@dpuse/dpuse-development').then(m => m.formatCode())\"",
        "lint": "node -e \"import('@dpuse/dpuse-development').then(m => m.lintCode())\"",
        "release": "op run --env-file=.env -- node -e \"import('@dpuse/dpuse-development').then(m => m.releaseProject())\"",
        "sync": "node -e \"import('@dpuse/dpuse-development').then(m => m.syncProjectWithGitHub())\"",
        "test": "node -e \"import('@dpuse/dpuse-development').then(m => m.testProject())\""
    },
    "dependencies": {
        "@dpuse/dpuse-shared": "^0.3.719",
        "@dpuse/dpuse-tool-csv-parse": "^0.0.143",
        "@dpuse/dpuse-tool-file-operators": "^0.0.24",
        "p-queue": "^9.3.0"
    },
    "devDependencies": {
        "@dpuse/dpuse-development": "^0.3.600",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@types/eslint-plugin-security": "^3.0.1",
        "@types/node": "^26.0.1",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import-x": "^4.17.1",
        "eslint-plugin-regexp": "^3.1.1",
        "eslint-plugin-security": "^4.0.1",
        "eslint-plugin-sonarjs": "^4.1.0",
        "eslint-plugin-unicorn": "^69.0.0",
        "jiti": "^2.7.0",
        "license-checker-rseidelsohn": "^5.0.1",
        "npm-check-updates": "^22.2.9",
        "prettier": "^3.9.4",
        "rollup-plugin-visualizer": "^7.0.1",
        "sonda": "^0.13.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.1.0",
        "vite-plugin-dts": "^5.0.3",
        "vitest": "^4.1.9",
        "wrangler": "^4.105.0"
    }
